---
import type { CollectionEntry } from "astro:content";
import {
  type BrokerStatus,
  brokerStatusLabels,
  formatBrokerFeeComponent,
  formatBrokerFeeTitle,
} from "../lib/broker-fees";

interface Props {
  entry: CollectionEntry<"docs">;
}

const { entry } = Astro.props;
const d = entry.data;

const feeRows = d.fees.flatMap((item) => {
  const prefix = formatBrokerFeeTitle(item);
  return [
    [`${prefix}佣金`, formatBrokerFeeComponent(item.commission)],
    ...(item.platformFee
      ? [[`${prefix}平台费`, formatBrokerFeeComponent(item.platformFee)]]
      : []),
    ...(item.note ? [[`${prefix}说明`, item.note]] : []),
  ] as [string, string][];
});

const rows: [string, string][] = [
  ["可开账户", d.accountTypes.length > 0 ? d.accountTypes.join(" / ") : "—"],
  [
    "当前状态",
    d.status
      ? brokerStatusLabels[d.status as BrokerStatus]
      : "未收录",
  ],
  ...(feeRows.length > 0 ? feeRows : [["费用", "未收录"] as [string, string]]),
  ["App 体验", d.appExperience ?? "—"],
  ["客服渠道", d.supportChannels.length > 0 ? d.supportChannels.join(" / ") : "—"],
  ["最低入金", d.minDeposit === null || d.minDeposit === undefined ? "—" : `¥${d.minDeposit}`],
  ["支持养老金账户", d.pensionSupported === undefined ? "—" : d.pensionSupported ? "是" : "否"],
  ["适合人群", d.targetGroupBroker ?? "—"],
];
---

<div class="spec">
  <table>
    <tbody>
      {
        rows.map(([label, value]) => (
          <tr>
            <th scope="row">{label}</th>
            <td>{value}</td>
          </tr>
        ))
      }
    </tbody>
  </table>

  {
    d.features.length > 0 && (
      <ul class="chips">
        {d.features.map((feature) => (
          <li class="chip">{feature}</li>
        ))}
      </ul>
    )
  }
</div>

<style>
  .spec {
    margin-bottom: 1.5rem;
  }

  .spec table {
    width: 100%;
    margin: 0;
  }

  .spec th {
    text-align: start;
    white-space: nowrap;
    width: 1%;
    color: var(--sl-color-gray-2);
    font-weight: 600;
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin-top: 1rem;
  }

  .chip {
    background: var(--sl-color-gray-7);
    color: var(--sl-color-white);
    border-radius: 999px;
    padding: 0.25rem 0.75rem;
    font-size: var(--sl-text-sm);
    line-height: 1.5;
  }
</style>
