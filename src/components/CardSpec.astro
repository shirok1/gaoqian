---
import type { CollectionEntry } from "astro:content";
import { Badge } from '@astrojs/starlight/components';

interface Props {
  entry: CollectionEntry<"docs">;
}

const { entry } = Astro.props;
const d = entry.data;

const currencySymbols: Record<string, string> = { CNY: "¥", HKD: "HK$", USD: "$" };
const formatFee = (fee: typeof d.annualFee) =>
  fee === undefined ? "—" : `${currencySymbols[fee.currency] ?? fee.currency + " "}${fee.amount}`;
const formatWaiver = (fee: typeof d.annualFee) =>
  fee === undefined ? "—" : fee.waiver ?? (fee.amount > 0 ? "刚性年费，不可减免" : "—");
const percent = (n: number | null | undefined) =>
  n === null || n === undefined ? "—" : `${n}%`;
const times = (n: number | null | undefined) =>
  n === null || n === undefined ? "—" : `${n}×`;

const rows: [string, string][] = [
  ["发卡行", d.bank ?? "—"],
  ["卡组织", d.network ?? "—"],
  ["卡片类型", d.cardType ?? "—"],
  ["卡片等级", d.cardLevel ?? "—"],
  ["年费", formatFee(d.annualFee)],
  ["免年费条件", formatWaiver(d.annualFee)],
  ["返现比例", percent(d.cashbackRate)],
  ["每元积分", times(d.pointsPerYuan)],
  ["适合人群", d.targetGroupCard ?? "—"],
  ["申请难度", d.difficulty ?? "—"],
];
---

<div class="spec">
  <table>
    <tbody>
      {
        rows.map(([label, value]) => (
          <tr>
            <th scope="row">{label}</th>
            <td>{value}</td>
          </tr>
        ))
      }
    </tbody>
  </table>

  {
    d.perks.length > 0 && d.perks.map((perk) => (
        <Badge text={perk} variant="note" />
      ))
  }
</div>

<style>
  .spec {
    margin-bottom: 1.5rem;
  }

  .spec table {
    width: 100%;
    margin: 0;
  }

  .spec th {
    text-align: start;
    white-space: nowrap;
    width: 1%;
    color: var(--sl-color-gray-2);
    font-weight: 600;
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin-top: 1rem;
  }

  .chip {
    background: var(--sl-color-gray-7);
    color: var(--sl-color-white);
    border-radius: 999px;
    padding: 0.25rem 0.75rem;
    font-size: var(--sl-text-sm);
    line-height: 1.5;
  }
</style>
